rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getZoneData(zoneId) {
      return get(/databases/$(database)/documents/zones/$(zoneId)).data;
    }

    // --- USERS Collection ---
    // Rule: owner can read/write their own document and all sub-collections
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Wildcard to ensure all sub-collections are covered for the owner
      match /{document=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- ZONES Collection ---
    // Temporarily allow authenticated users to read zones for the dashboard to load
    match /zones/{zoneId} {
      allow read: if isSignedIn();
      // Only the creator can write
      allow write: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      // ZONES/STUDENTS Sub-collection
      // Rule: read if studentId or zone creator (Thala). 
      // This enables aggregation (count) for tutors on their own zones.
      match /students/{studentId} {
        allow read: if isSignedIn() && (
          request.auth.uid == studentId || 
          get(/databases/$(database)/documents/zones/$(zoneId)).data.createdBy == request.auth.uid
        );
        allow write: if false;
      }

      // ZONES/INVITES Sub-collection
      // Rule: read/write only for zone creator
      match /invites/{inviteId} {
        allow read, write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;
      }

      // ZONES/EXAMS Sub-collection
      // Rule: read if active student OR creator, write if creator only
      match /exams/{examId} {
        allow read: if isSignedIn() && (
          exists(/databases/$(database)/documents/zones/$(zoneId)/students/$(request.auth.uid)) ||
          request.auth.uid == getZoneData(zoneId).createdBy
        );
        allow write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;

        // ZONES/EXAMS/SUBMISSIONS Sub-collection
        // Rule: read if studentId or creator, no client writes
        match /submissions/{studentId} {
          allow read: if isSignedIn() && (request.auth.uid == studentId || getZoneData(zoneId).createdBy == request.auth.uid);
          allow write: if false;
        }
      }

      // ZONES/ORDERS Sub-collection
      // Rule: read if studentUid or creator, no client writes
      match /orders/{orderId} {
        allow read: if isSignedIn() && (request.auth.uid == resource.data.studentUid || getZoneData(zoneId).createdBy == request.auth.uid);
        allow write: if false;
      }

      // ZONES/VIDEOS Sub-collection
      match /videos/{videoId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;
      }

      // ZONES/CHAPTERS Sub-collection
      match /chapters/{chapterId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;
      }

      // ZONES/SESSIONS Sub-collection
      match /sessions/{sessionId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;

        match /attendance/{attendeeId} {
          allow read, write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;
        }
      }

      // ZONES/ATTENDANCE_SESSIONS Sub-collection
      match /attendance_sessions/{sessionId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;
      }
    }

    // --- CERTIFICATES Collection ---
    // Rule: read if studentId or issuedBy, no client writes
    match /certificates/{certId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.issuedBy);
      allow write: if false;
    }

    // --- OTPS Collection ---
    // Rule: deny all client reads and writes
    match /otps/{email} {
      allow read, write: if false;
    }

    // --- PLATFORM ORDERS Collection ---
    // Rule: only the tutor who created the order can read it
    match /platform_orders/{orderId} {
      allow read: if isSignedIn() && resource.data.tutorId == request.auth.uid;
      allow write: if false;
    }

    // --- PRODUCTS Collection ---
    // Rule: public read, write for THALA role only if tutorId matches
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn() 
        && getUserData(request.auth.uid).role == 'THALA'
        && (request.method == 'delete' ? resource.data.tutorId == request.auth.uid : request.resource.data.tutorId == request.auth.uid);
    }
  }
}
