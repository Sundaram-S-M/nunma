rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to subcollections like enrollments
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Allow reading zones for authenticated users
    match /zones/{zoneId} {
      allow read: if request.auth != null;
      // Only the creator can update the zone
      allow write: if request.auth != null && (resource == null || resource.data.createdBy == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
      
      // Student subcollections in zones
      match /students/{studentId} {
        allow read, write: if request.auth != null && (request.auth.uid == studentId || get(/databases/$(database)/documents/zones/$(zoneId)).data.createdBy == request.auth.uid);
      }
      
      // Exam results
      match /exam_results/{resultId} {
        allow read: if request.auth != null && (request.auth.uid == resource.data.studentId || get(/databases/$(database)/documents/zones/$(zoneId)).data.createdBy == request.auth.uid);
        allow create: if request.auth != null;
      }
      
      // Allow all access to other subcollections inside zones for now to avoid blockers
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
