rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own data
    // Allow users to read and write their own data
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow user to edit their own profile OR others to update followers count
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']));
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to subcollections like enrollments
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;+
      }
    }

    // Chat / Conversations Rules
    match /conversations/{conversationId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants);
      allow create: if request.auth != null && (request.auth.uid in request.resource.data.participants);
      allow update: if request.auth != null && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Allow reading zones for authenticated users
    match /zones/{zoneId} {
      allow read: if request.auth != null;
      // Only the creator can update the zone
      allow write: if request.auth != null && (resource == null || resource.data.createdBy == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
      
      // Student subcollections in zones
      match /students/{studentId} {
        allow read, write: if request.auth != null && (request.auth.uid == studentId || get(/databases/$(database)/documents/zones/$(zoneId)).data.createdBy == request.auth.uid);
      }
      
      // Exam results
      match /exam_results/{resultId} {
        allow read: if request.auth != null && (request.auth.uid == resource.data.studentId || get(/databases/$(database)/documents/zones/$(zoneId)).data.createdBy == request.auth.uid);
        allow create: if request.auth != null;
      }
      
      // Allow all access to other subcollections inside zones for now to avoid blockers
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Products Rules
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.tutorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.tutorId == request.auth.uid;
    }

    // Followers Rules
    match /followers/{followerDocId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
