rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getZoneData(zoneId) {
      return get(/databases/$(database)/documents/zones/$(zoneId)).data;
    }

    // --- USERS Collection ---
    // Rule: read auth.uid === userId
    // Rule: write auth.uid === userId (block sensitive fields: role, kycStatus, razorpayAccountId, kycSubmittedAt)
    match /users/{userId} {
      allow read: if isUser(userId);
      allow create: if isUser(userId) 
        && !request.resource.data.keys().hasAny(['role', 'kycStatus', 'razorpayAccountId', 'kycSubmittedAt']);
      allow update: if isUser(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'kycStatus', 'razorpayAccountId', 'kycSubmittedAt']);
      
      // Invoices sub-collection: read auth.uid === userId, no client writes
      match /invoices/{invoiceId} {
        allow read: if isUser(userId);
        allow write: if false;
      }
    }

    // --- ZONES Collection ---
    // Rule: anyone can read zone metadata
    // Rule: create only for THALA role
    // Rule: update/delete only for creator
    // Rule: block client writes to price, priceINR, currency
    match /zones/{zoneId} {
      allow read: if true;
      allow create: if isSignedIn() && getUserData(request.auth.uid).role == 'THALA'
        && !request.resource.data.keys().hasAny(['price', 'priceINR', 'currency']);
      allow update: if isSignedIn() && request.auth.uid == resource.data.createdBy
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['price', 'priceINR', 'currency']);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;

      // ZONES/STUDENTS Sub-collection
      // Rule: read if studentId or zone creator, no client writes
      match /students/{studentId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || getZoneData(zoneId).createdBy == request.auth.uid);
        allow write: if false;
      }

      // ZONES/INVITES Sub-collection
      // Rule: read/write only for zone creator
      match /invites/{inviteId} {
        allow read, write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;
      }

      // ZONES/EXAMS Sub-collection
      // Rule: read if active student OR creator, write if creator only
      match /exams/{examId} {
        allow read: if isSignedIn() && (
          exists(/databases/$(database)/documents/zones/$(zoneId)/students/$(request.auth.uid)) ||
          request.auth.uid == getZoneData(zoneId).createdBy
        );
        allow write: if isSignedIn() && request.auth.uid == getZoneData(zoneId).createdBy;

        // ZONES/EXAMS/SUBMISSIONS Sub-collection
        // Rule: read if studentId or creator, no client writes
        match /submissions/{studentId} {
          allow read: if isSignedIn() && (request.auth.uid == studentId || getZoneData(zoneId).createdBy == request.auth.uid);
          allow write: if false;
        }
      }

      // ZONES/ORDERS Sub-collection
      // Rule: read if studentUid or creator, no client writes
      match /orders/{orderId} {
        allow read: if isSignedIn() && (request.auth.uid == resource.data.studentUid || getZoneData(zoneId).createdBy == request.auth.uid);
        allow write: if false;
      }

      // ZONES/STUDENTS Sub-collection
      match /students/{studentUid} {
        allow read, write: if isSignedIn();
      }

      // ZONES/VIDEOS Sub-collection
      match /videos/{videoId} {
        allow read, write: if isSignedIn();
      }

      // ZONES/CHAPTERS Sub-collection
      match /chapters/{chapterId} {
        allow read, write: if isSignedIn();
      }

      // ZONES/SESSIONS Sub-collection
      match /sessions/{sessionId} {
        allow read, write: if isSignedIn();

        match /attendance/{attendeeId} {
          allow read, write: if isSignedIn();
        }
      }

      // ZONES/ATTENDANCE_SESSIONS Sub-collection
      match /attendance_sessions/{sessionId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- CERTIFICATES Collection ---
    // Rule: read if studentId or issuedBy, no client writes
    match /certificates/{certId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.issuedBy);
      allow write: if false;
    }

    // --- OTPS Collection ---
    // Rule: deny all client reads and writes
    match /otps/{email} {
      allow read, write: if false;
    }

    // --- PRODUCTS Collection ---
    // Rule: public read, write for THALA role only if tutorId matches
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn() 
        && getUserData(request.auth.uid).role == 'THALA'
        && (request.method == 'delete' ? resource.data.tutorId == request.auth.uid : request.resource.data.tutorId == request.auth.uid);
    }
  }
}
