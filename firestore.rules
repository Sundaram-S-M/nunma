rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getZoneData(zoneId) {
      return get(/databases/$(database)/documents/zones/$(zoneId)).data;
    }

    function isZoneCreator(zoneId) {
      let zoneDoc = get(/databases/$(database)/documents/zones/$(zoneId));
      return request.auth != null && (
        request.auth.uid == zoneDoc.data.tutorId || 
        request.auth.uid == zoneDoc.data.createdBy
      );
    }

    // --- ZONES Collection ---
    match /zones/{zoneId} {
      // Zone read is public for authenticated users to support explore/dashboard
      allow read: if isSignedIn();
      
      // Allow creation for authenticated users
      allow create: if isSignedIn();
      
      // Only creators can update metadata, and pricing fields are immutable
      allow update: if isSignedIn() && (
        resource.data.tutorId == request.auth.uid || 
        resource.data.createdBy == request.auth.uid
      ) && (
        request.resource.data.get('price', null) == resource.data.get('price', null) &&
        request.resource.data.get('priceINR', null) == resource.data.get('priceINR', null) &&
        request.resource.data.get('currency', null) == resource.data.get('currency', null)
      );

      allow delete: if isSignedIn() && (
        resource.data.tutorId == request.auth.uid || 
        resource.data.createdBy == request.auth.uid
      );
    }

    // --- ZONES SUB-COLLECTIONS (Hardened Paths) ---

    // ZONES/STUDENTS
    match /zones/{zoneId}/students/{studentId} {
      allow read: if isSignedIn() && (request.auth.uid == studentId || isZoneCreator(zoneId));
      allow write: if false; // Managed by Cloud Functions
    }

    // ZONES/CHAPTERS (Priority Fix)
    match /zones/{zoneId}/chapters/{chapterId} {
      // Broad read for authenticated users to avoid snapshot listener failures
      allow read: if isSignedIn(); 
      // Only creators can manage curriculum
      allow write: if isSignedIn() && isZoneCreator(zoneId);
    }

    // ZONES/VIDEOS
    match /zones/{zoneId}/videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isZoneCreator(zoneId);
    }

    // ZONES/EXAMS
    match /zones/{zoneId}/exams/{examId} {
      allow read: if isSignedIn() && (
        exists(/databases/$(database)/documents/zones/$(zoneId)/students/$(request.auth.uid)) ||
        isZoneCreator(zoneId)
      );
      allow write: if isSignedIn() && isZoneCreator(zoneId);

      match /submissions/{studentId} {
        allow read: if isSignedIn() && (request.auth.uid == studentId || isZoneCreator(zoneId));
        allow write: if false;
      }
    }

    // ZONES/ORDERS
    match /zones/{zoneId}/orders/{orderId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.studentUid || isZoneCreator(zoneId));
      allow write: if false;
    }

    // ZONES/INVITES
    match /zones/{zoneId}/invites/{inviteId} {
      allow read, write: if isSignedIn() && isZoneCreator(zoneId);
    }

    // ZONES/SESSIONS & ATTENDANCE
    match /zones/{zoneId}/sessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isZoneCreator(zoneId);
      
      match /attendance/{attendeeId} {
        allow read, write: if isSignedIn() && isZoneCreator(zoneId);
      }
    }

    match /zones/{zoneId}/attendance_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isZoneCreator(zoneId);
    }


    // --- CERTIFICATES Collection ---
    // Rule: read if studentId or issuedBy, no client writes
    match /certificates/{certId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.issuedBy);
      allow write: if false;
    }

    // --- OTPS Collection ---
    // Rule: deny all client reads and writes
    match /otps/{email} {
      allow read, write: if false;
    }

    // --- PLATFORM ORDERS Collection ---
    // Rule: only the tutor who created the order can read it
    match /platform_orders/{orderId} {
      allow read: if isSignedIn() && resource.data.tutorId == request.auth.uid;
      allow write: if false;
    }

    // --- PRODUCTS Collection ---
    // Rule: public read, write for THALA role only if tutorId matches
    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn() 
        && getUserData(request.auth.uid).role == 'THALA'
        && (request.method == 'delete' ? resource.data.tutorId == request.auth.uid : request.resource.data.tutorId == request.auth.uid);
    }
    // --- USERS Collection ---
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
