rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- USER PROFILE RULES ---
    match /users/{userId} {
      // Allow general read for authenticated users (to view profile basic info)
      allow read: if request.auth != null;
      
      // Strict ownership for profile management
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId; // Full access for testing
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // CRITICAL SECURITY: SENSITIVE KYC DATA LOCKDOWN
      // The 'taxDetails' subcollection contains PII/Financial data.
      // This is EXPLICITLY LOCKED from client-side access.
      // Only Admin SDK (Cloud Functions) can interact with this path.
      match /taxDetails/{document=**} {
        allow read, write: if false;
      }
      
      // Allow access to other subcollections (orders, enrollments, etc.) 
      // ONLY if they are NOT the sensitive taxDetails path.
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId 
          && !('taxDetails' in request.path);
      }
    }

    // --- CHAT / CONVERSATIONS RULES ---
    match /conversations/{conversationId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants);
      allow create: if request.auth != null && (request.auth.uid in request.resource.data.participants);
      allow update: if request.auth != null && (request.auth.uid in resource.data.participants);

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // --- ZONE & CONTENT RULES ---
    match /zones/{zoneId} {
      // Zones are public/shared but content is gated
      allow read: if request.auth != null;
      
      // Only the creator/tutor can modify the zone config
      allow write: if request.auth != null && (resource == null || resource.data.createdBy == request.auth.uid || request.resource.data.createdBy == request.auth.uid);
      
      // Student-specific enrollment data within a zone
      match /students/{studentId} {
        allow read, write: if request.auth != null && (request.auth.uid == studentId || get(/databases/$(database)/documents/zones/$(zoneId)).data.createdBy == request.auth.uid);
      }
      
      // Exam and results logic (Simplified for MVP)
      match /exams/{examId} {
        allow read, write: if request.auth != null;
      }

      match /exam_results/{resultId} {
        allow read: if request.auth != null && (request.auth.uid == resource.data.studentId || get(/databases/$(database)/documents/zones/$(zoneId)).data.createdBy == request.auth.uid);
        allow create: if request.auth != null;
      }
      
      // recursive catch-all for zone content (videos, segments, etc.)
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    // --- PRODUCTS & COMMERCE ---
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.tutorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.tutorId == request.auth.uid;
    }

    // --- SOCIAL / FOLLOWERS ---
    match /followers/{followerDocId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // --- SYSTEM LOGS & IDEMPOTENCY ---
    match /system/webhooks/processed/{eventId} {
      allow read, write: if false; // Internal system path
    }
  }
}
